# Phase 42 — Stripe Checkout pricing (PREREQ-B + PREREQ-E)
# Price IDs are created in Stripe Dashboard (test mode for dev, live for prod).
# Source: Stripe Dashboard -> Products -> [Subscription product] -> copy price_id for each interval.
STRIPE_PRICE_ID_MONTHLY=price_placeholder_monthly
STRIPE_PRICE_ID_ANNUAL=price_placeholder_annual
# Amounts in CENTS — used for "Save X%" calculation and "$/month" label rendering.
# MUST match the actual Stripe Price amounts exactly (PREREQ-E final values).
# Example: $29/month = 2900, $232/year = 23200
STRIPE_PRICE_MONTHLY_CENTS=2900
STRIPE_PRICE_ANNUAL_CENTS=27840
