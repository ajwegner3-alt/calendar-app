# === Stripe Pricing — Phase 42.5 Multi-Tier ===
# Four Price IDs, one per (tier, interval). Created in Stripe Dashboard
# under a single Product. Required in production; placeholders used in dev.
STRIPE_PRICE_ID_BASIC_MONTHLY=price_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_ID_BASIC_ANNUAL=price_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_ID_WIDGET_MONTHLY=price_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_ID_WIDGET_ANNUAL=price_xxxxxxxxxxxxxxxxxxxxxxxx

# Cents amounts for UI labels (must match the Stripe Price unit_amount exactly,
# otherwise the displayed price will lie to the user).
STRIPE_PRICE_BASIC_MONTHLY_CENTS=2900
STRIPE_PRICE_BASIC_ANNUAL_CENTS=27840
STRIPE_PRICE_WIDGET_MONTHLY_CENTS=4900
STRIPE_PRICE_WIDGET_ANNUAL_CENTS=47040

# === Branding Tier (non-Stripe consult link) — Phase 42.5 ===
# Server-side ONLY (do NOT prefix with NEXT_PUBLIC_). Read in app/(shell)/app/billing/page.tsx
# and passed as a prop to the ConsultTierCard. Hardcoded fallback ensures the
# link never renders blank.
NSI_BRANDING_BOOKING_URL=https://booking.nsintegrations.com/nsi/branding-consultation
