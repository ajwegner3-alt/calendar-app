NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Phase 2 — Vitest authenticated-owner test helper (primary tenant: nsi).
# Set these in .env.local (which is gitignored). Real values are set by
# Plan 02-04 after Andrew creates his auth user in the Supabase dashboard.
TEST_OWNER_EMAIL=
TEST_OWNER_PASSWORD=

# Phase 8 — Vitest second-tenant test helper (Plan 08-08 RLS cross-tenant matrix).
# Required for the cross-tenant RLS isolation test suite. Setup:
#   1. Supabase Dashboard → Authentication → Users → "Add user" (auto-confirm email)
#   2. SQL Editor: INSERT INTO accounts (slug, name, owner_user_id, timezone, owner_email)
#                  VALUES ('nsi-rls-test', 'NSI RLS Test', '<new-user-uuid>', 'America/Chicago', '<email>');
#   3. Paste credentials in .env.local. Quote password if it contains '#' or '$'.
TEST_OWNER_2_EMAIL=
TEST_OWNER_2_PASSWORD=

# Phase 5 — Cloudflare Turnstile (booking form bot protection)
# Create a site at: Cloudflare Dashboard -> Turnstile -> Add site
#   Domain: calendar-app-xi-smoky.vercel.app + localhost | Widget mode: Managed
# Test keys for local dev (always pass, never block):
#   Site key  (always passes): 1x00000000000000000000AA
#   Secret key (always passes): 1x0000000000000000000000000000000AA
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Phase 5 — Email provider selection. Default: "gmail" (nodemailer SMTP via App Password).
# v2 multi-tenant onboarding will introduce a third provider "gmail-oauth" that uses
# per-account refresh tokens stored in accounts.gmail_refresh_token. Until then, single-
# tenant v1 sends from Andrew's Gmail address using an App Password.
EMAIL_PROVIDER=gmail

# Phase 5 — Gmail (default provider, used for v1 single-tenant)
# 1. Enable 2-Step Verification: https://myaccount.google.com/security
# 2. Generate an App Password: https://myaccount.google.com/apppasswords
#    Choose "Mail" + custom device name "calendar-app"
# 3. GMAIL_USER MUST equal accounts.owner_email for the seeded account (nsi).
#    The .ics ORGANIZER and outbound From: header both read from this address.
GMAIL_USER=
GMAIL_APP_PASSWORD=
GMAIL_FROM_NAME=Andrew @ NSI

# Phase 5 — Resend (alternative provider; not used in v1 — kept for future option)
# To switch: set EMAIL_PROVIDER=resend and populate the two vars below.
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev

# Phase 8 — Vercel Cron shared secret (Plan 08-04 + 08-08).
# The /api/cron/send-reminders Route Handler verifies inbound calls with
# `Authorization: Bearer ${CRON_SECRET}`. Must match between Vercel project
# env (Production + Preview) and .env.local for parity. Generate with:
#   openssl rand -hex 32
# Vercel's built-in cron runner attaches this header automatically when the
# var is set in the project. Required for production reminder delivery.
CRON_SECRET=

# Phase 8 — Reminder cron schedule (vercel.json `crons[].schedule`).
# Hobby tier: max once-daily (`0 8 * * *`). Pro tier: hourly OK (`0 * * * *`).
# This project is on Pro as of Plan 08-08; vercel.json schedule is hourly.
# Not an env var — documented here as a deployment-time concern.

# Phase 8 — App / public URLs (used by reminder email links + cron self-ping).
# APP_URL is the canonical production origin; NEXT_PUBLIC_APP_URL is exposed
# to client bundles for browser-side absolute URL construction.
APP_URL=https://calendar-app-xi-smoky.vercel.app
NEXT_PUBLIC_APP_URL=https://calendar-app-xi-smoky.vercel.app
